{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "electron:dev:debug",
      "type": "shell",
      "command": "npm run dev:debug",
      "options": {
        "cwd": "${workspaceFolder}/apps/desktop"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "electron",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Debugger listening on ws://127\\.0\\.0\\.1:5858"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
